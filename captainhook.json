{
    "$schema": "https://captainhookphp.github.io/captainhook/schema.json",
    "config": {
        "run-mode": "php"
    },
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\\(.+\\))?!?:\\s.{1,100}$/",
                    "error": "Commit message must follow Conventional Commits format: <type>(<scope>): <description>"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\PHP\\Action\\Linting",
                "options": {
                    "extensions": "php"
                }
            },
            {
                "action": "echo 'Scanning staged changes for secrets...' && gitleaks protect --staged --verbose --redact --config=.gitleaks.toml"
            },
            {
                "action": "echo 'Running Pint...' && composer lint:pint"
            },
            {
                "action": "echo 'Running PHPCS...' && composer lint:phpcs"
            },
            {
                "action": "echo 'Running PHPStan...' && composer lint:phpstan"
            },
            {
                "action": "echo 'Running PHPMD...' && composer lint:phpmd"
            },
            {
                "action": "echo 'Running PHP-CS-Fixer...' && composer lint:cs"
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "echo 'Scanning unpushed commits for secrets...' && if command -v gitleaks >/dev/null 2>&1; then BASE_REF=$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/@@') && gitleaks detect --verbose --redact --config=.gitleaks.toml --log-opts=\"${BASE_REF}..HEAD\"; else echo 'Note: install gitleaks locally to enable pre-push secret scans'; fi"
            },
            {
                "action": "echo 'Running tests...' && composer test"
            }
        ]
    }
}
